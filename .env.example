# AiChat 运行时配置
# Vite build 时把 VITE_* 前缀变量打包进客户端 bundle
# CI 按环境 (dev/staging/prod) 注入 VITE_AI_API_HOST 与 VITE_AI_API_ENDPOINT
# 其余变量留空即可，代码内有默认值

# AI 服务域名；生产构建时直接拼入请求 URL，dev 模式由 Vite proxy 转发
VITE_AI_API_HOST=https://your-api-host.example.com

# AI 调用 endpoint；未注入时代码默认 '/api/forward/v1/customer-service/docs/chat'
VITE_AI_API_ENDPOINT=/api/forward/v1/customer-service/docs/chat

# 账号渠道；未注入时代码默认 'lb'
VITE_AI_ACCOUNT_CHANNEL=lb

# 应用标识；未注入时代码默认 'longbridge'
VITE_AI_APP_ID=longbridge
